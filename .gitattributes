# Normalize line endings for cross-platform sync (Windows + WSL2/Linux)
* text=auto eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.py text eol=lf
*.sh text eol=lf

# Binary files — leave as-is
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
