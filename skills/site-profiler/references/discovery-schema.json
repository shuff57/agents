{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SiteProfile",
  "type": "object",
  "required": ["url", "domain", "pageName", "profiledAt", "interactive", "summary"],
  "properties": {
    "url": { "type": "string", "description": "Full URL of the profiled page" },
    "domain": { "type": "string", "description": "Hostname (e.g., example.com)" },
    "pageName": { "type": "string", "description": "Kebab-cased page identifier" },
    "profiledAt": { "type": "string", "format": "date-time" },
    "title": { "type": "string", "description": "Page <title> at profile time" },
    "goal": { "type": "string", "description": "User's stated goal for this page" },

    "interactive": {
      "type": "object",
      "properties": {
        "buttons": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["text", "selector"],
            "properties": {
              "text": { "type": "string" },
              "selector": { "type": "string", "description": "Best-ranked CSS/Playwright selector" },
              "purpose": { "type": "string", "description": "Discovered purpose (e.g., start-video, submit-quiz)" },
              "candidates": { "type": "array", "items": { "$ref": "#/definitions/SelectorCandidate" } },
              "disabled": { "type": "boolean" },
              "context": { "$ref": "#/definitions/ElementContext" }
            }
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["text", "selector"],
            "properties": {
              "text": { "type": "string" },
              "selector": { "type": "string" },
              "href": { "type": "string" },
              "purpose": { "type": "string" },
              "candidates": { "type": "array", "items": { "$ref": "#/definitions/SelectorCandidate" } },
              "context": { "$ref": "#/definitions/ElementContext" }
            }
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "selector"],
            "properties": {
              "label": { "type": "string" },
              "type": { "type": "string" },
              "selector": { "type": "string" },
              "required": { "type": "boolean" },
              "candidates": { "type": "array", "items": { "$ref": "#/definitions/SelectorCandidate" } },
              "context": { "$ref": "#/definitions/ElementContext" }
            }
          }
        },
        "selects": { "type": "array" },
        "checkboxes": { "type": "array" },
        "radios": { "type": "array" },
        "forms": { "type": "array" }
      }
    },

    "workflows": {
      "type": "array",
      "description": "Recorded interaction sequences for this page",
      "items": {
        "type": "object",
        "required": ["name", "steps"],
        "properties": {
          "name": { "type": "string", "description": "Kebab-cased workflow identifier" },
          "trigger": { "type": "string", "description": "When to use this workflow" },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["action"],
              "properties": {
                "action": {
                  "type": "string",
                  "enum": ["click", "fill", "select", "wait-for", "answer-quiz", "navigate", "keyboard", "scroll"]
                },
                "selector": { "type": "string" },
                "value": { "type": "string", "description": "For fill/select actions" },
                "key": { "type": "string", "description": "For keyboard actions (e.g., 'k' for play)" },
                "frame": { "type": "string", "description": "Iframe selector if action is inside a frame" },
                "context": { "type": "string", "enum": ["outer", "iframe"] },
                "condition": { "type": "string", "description": "For wait-for actions" },
                "timeout": { "type": "number", "description": "Max wait in ms" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "frames": {
      "type": "object",
      "description": "Detected iframes with access metadata",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "selector": { "type": "string" },
          "origin": { "type": "string" },
          "crossOrigin": { "type": "boolean" },
          "accessible": { "type": "boolean", "description": "Can we query elements inside?" },
          "note": { "type": "string" }
        }
      }
    },

    "landmarks": { "type": "object" },
    "headings": { "type": "array" },
    "summary": {
      "type": "object",
      "properties": {
        "buttons": { "type": "number" },
        "links": { "type": "number" },
        "inputs": { "type": "number" },
        "selects": { "type": "number" },
        "checkboxes": { "type": "number" },
        "radios": { "type": "number" },
        "forms": { "type": "number" },
        "landmarks": { "type": "number" },
        "headings": { "type": "number" }
      }
    }
  },

  "definitions": {
    "SelectorCandidate": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["data-testid", "id", "role-name", "name", "placeholder", "class"] },
        "value": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "ElementContext": {
      "type": "object",
      "properties": {
        "landmark": { "type": "string" },
        "landmarkLabel": { "type": "string" },
        "form": { "type": "string" },
        "nearestHeading": { "type": "string" }
      }
    }
  }
}
