      "model": "anthropic/claude-sonnet-4-6"
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "sisyphus-junior": {
      "model": "ollama-cloud/glm-5.1"
    },
    "scout": {
      "model": "ollama-cloud/qwen3-coder-next"
    },
    "planner": {
      "model": "anthropic/claude-sonnet-4-6"
    },
